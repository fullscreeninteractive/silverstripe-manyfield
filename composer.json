{
    "name": "fullscreeninteractive/silverstripe-manyfield",
    "description": "SilverStripe FormField for adding dynamic data to forms.",
    "type": "silverstripe-vendormodule",
    "homepage": "http://silverstripe.org",
    "license": "BSD-3-Clause",
    "keywords": [
        "silverstripe",
        "versioned"
    ],
    "authors": [
        {
            "name": "Will Rossiter",
            "homepage": "http://www.fullscreen.io"
        }
    ],
    "require": {
        "silverstripe/framework": "^6",
        "silverstripe/vendor-plugin": "^3"
    },
    "require-dev": {
        "cambis/silverstan": "^2.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "silverstripe/userforms": "^7",
        "symbiote/silverstripe-gridfieldextensions": "^5"
    },
    "autoload": {
        "psr-4": {
            "FullscreenInteractive\\ManyField\\": "src/",
            "FullscreenInteractive\\ManyField\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": [
            "@lint:phpstan"
        ],
        "lint:phpstan": "phpstan analyse --memory-limit=1G",
        "test": "phpunit",
        "coverage": "phpunit --coverage-text"
    },
    "extra": {
        "expose": [
            "client"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true
        }
    }
}
