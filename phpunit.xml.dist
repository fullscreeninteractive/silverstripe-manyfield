<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="vendor/autoload.php"
    colors="true"
    beStrictAboutChangesToGlobalState="false"
>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>

    <testsuites>
        <testsuite name="ManyField">
            <directory>tests/php</directory>
        </testsuite>
    </testsuites>
</phpunit>
